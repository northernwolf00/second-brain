{
  "expo": {
    "name": "SecondBrain",
    "slug": "second-brain",
    "scheme": "secondbrain",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.googadev.secondbrainapp"
    },
    "android": {
      "package": "com.googadev.secondbrainapp"
    },
    "plugins": [
      "expo-secure-store",
      "expo-web-browser"
    ]
  }
}
